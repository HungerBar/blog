---
import {
  buildTagTree,
  flattenTagTree,
  formatDate,
  groupPostsByMonth,
} from "../lib/content.mjs";
import { getPublishedPosts } from "../lib/posts.mjs";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = await getPublishedPosts();
const archive = groupPostsByMonth(posts);
const tags = flattenTagTree(buildTagTree(posts));
const shellPosts = posts.map((post) => ({
  slug: post.slug,
  title: post.title,
  date: formatDate(post.date),
  tags: post.tags,
  excerpt: post.excerpt,
  body: post.body,
  url: post.url,
}));
const shellArchive = archive.map((group) => ({
  label: group.label,
  posts: group.posts.map((post) => ({
    slug: post.slug,
    title: post.title,
    date: formatDate(post.date),
    tags: post.tags,
    excerpt: post.excerpt,
    body: post.body,
    url: post.url,
  })),
}));
const shellTags = tags.map((tag) => ({
  path: tag.path,
  count: tag.count,
  depth: tag.depth,
}));
const latestDate = shellPosts[0]?.date ?? "";
---

<BaseLayout title="Blog" section="shell">
  <section class="terminal" data-terminal>
    <div class="home-stage" data-home-stage>
      <pre class="pixel-logo" aria-label="Hungerbar">
█   █ █   █ █   █  ███  █████ ████  ████   ███  ████
█   █ █   █ ██  █ █   █ █     █   █ █   █ █   █ █   █
█████ █   █ █ █ █ █     ███   ████  ████  █████ ████
█   █ █   █ █  ██ █  ██ █     █  █  █   █ █   █ █  █
█   █  ███  █   █  ███  █████ █   █ ████  █   █ █   █
      </pre>
    </div>

    <div class="terminal-output" data-output tabindex="0"></div>

    <p class="home-actions" data-home-actions>
      <a class="resume-link" href="/resume/">resume</a>
    </p>

    <p class="help-hint" data-help-hint>type `help` to list commands</p>

    <form class="terminal-input" data-command-form>
      <span class="prompt" data-prompt>~/blog $</span>
      <span class="mode-indicator" data-mode-indicator>[INSERT]</span>
      <span class="command-entry">
        <span class="normal-command-view" data-normal-command-view aria-hidden="true"></span>
        <input
          data-command-input
          autocomplete="off"
          spellcheck="false"
          aria-label="Command input"
          autofocus
        />
      </span>
    </form>
  </section>

  <script define:vars={{ posts: shellPosts, archive: shellArchive, tags: shellTags, latestDate }}>
    const form = document.querySelector("[data-command-form]");
    const input = document.querySelector("[data-command-input]");
    const output = document.querySelector("[data-output]");
    const prompt = document.querySelector("[data-prompt]");
    const modeIndicator = document.querySelector("[data-mode-indicator]");
    const normalCommandView = document.querySelector("[data-normal-command-view]");
    const homeStage = document.querySelector("[data-home-stage]");
    const homeActions = document.querySelector("[data-home-actions]");
    let latestResults = [];
    let mode = "shell";
    let inputMode = "insert";
    let focusPane = "input";
    let outputCursorIndex = 0;
    let outputCursorColumn = 0;
    let savedShellOutput = "";
    let activePost = null;
    let focusTimer;
    let visualAnchor = null;
    let visualFocus = null;

    const SHELL_STATE_KEY = "hungerbar:shell-state";
    const commands = [
      ["help", "show this command list"],
      ["search <query>", "fuzzy search posts by title, date, excerpt, or tag"],
      ["recent [n]", "show the latest posts, default 10"],
      ["time <date>", "filter by date; examples: 2026, 06月, 07-02, 02"],
      ["archive", "show posts grouped by month"],
      ["tags", "show the nested tag tree"],
      ["tag <path>", "show posts under a tag, e.g. tag tech/ai/agent"],
      ["open <number>", "open a post in vim-style reader. Run recent, search, or tag first to choose a numbered result."],
      ["resume", "open the resume page"],
      ["clear", "clear terminal output"],
    ];
    const commandNames = commands.map(([command]) => command.split(" ")[0]);

    function line(text = "", className = "") {
      const element = document.createElement("p");
      element.className = ["terminal-line", className].filter(Boolean).join(" ");
      element.dataset.rawText = text;
      element.textContent = text;
      output.append(element);
      if (focusPane === "output") {
        setOutputCursor(outputCursorIndex);
      }
      return element;
    }

    function linkLine(label, href, className = "") {
      const element = document.createElement("p");
      element.className = ["terminal-line", className].filter(Boolean).join(" ");
      element.dataset.rawText = label;
      const link = document.createElement("a");
      link.href = href;
      link.textContent = label;
      element.append(link);
      output.append(element);
      if (focusPane === "output") {
        setOutputCursor(outputCursorIndex);
      }
    }

    function saveShellState() {
      clearOutputCursor();
      const state = {
        outputHtml: output.innerHTML,
        resultSlugs: latestResults.map((post) => post.slug),
        homeStageHidden: Boolean(homeStage?.hidden),
        scrollTop: output.scrollTop,
      };
      sessionStorage.setItem(SHELL_STATE_KEY, JSON.stringify(state));
    }

    function restoreShellState() {
      const rawState = sessionStorage.getItem(SHELL_STATE_KEY);
      if (!rawState) {
        return;
      }

      try {
        const state = JSON.parse(rawState);
        output.innerHTML = state.outputHtml || "";
        latestResults = state.resultSlugs
          .map((slug) => posts.find((post) => post.slug === slug))
          .filter(Boolean);
        if (state.homeStageHidden) {
          dismissHomeStage();
        } else {
          restoreHomeStage();
        }
        output.scrollTop = Number(state.scrollTop) || 0;
      } catch {
        sessionStorage.removeItem(SHELL_STATE_KEY);
      }
    }

    function navigateToPost(post) {
      saveShellState();
      window.location.href = post.url;
    }

    function handlePostLinkClick(event) {
      const link = event.target.closest("a");
      if (!link) {
        return;
      }

      const post = posts.find((item) => item.url === link.pathname);
      if (post) {
        saveShellState();
      }
    }

    function activateFocusedLink() {
      if (focusPane !== "output") {
        return false;
      }

      const target = getOutputCursorTargets()[outputCursorIndex];
      const link = target?.querySelector("a[href]");
      if (!link) {
        return false;
      }

      saveShellState();
      window.location.href = link.href;
      return true;
    }

    function echo(command) {
      line(`~/blog $ ${command}`, "echo");
    }

    function updateModeIndicator() {
      if (modeIndicator) {
        modeIndicator.textContent = `[${inputMode.toUpperCase()}]`;
      }
    }

    function setInputMode(nextMode, options = {}) {
      if (nextMode !== "visual") {
        clearVisualSelection();
      }
      inputMode = nextMode;
      document.body.dataset.inputMode = nextMode;
      updateModeIndicator();

      input.focus();
      focusPane = "input";
      document.body.dataset.focusPane = focusPane;
      clearOutputCursor();
      if (options.append) {
        input.setSelectionRange(input.value.length, input.value.length);
      }
      updateCursorView();
    }

    function focusOutput() {
      inputMode = "normal";
      document.body.dataset.inputMode = "normal";
      updateModeIndicator();
      focusPane = "output";
      document.body.dataset.focusPane = focusPane;
      output.focus();
      setOutputCursor(outputCursorIndex);
      flashFocusRing(output);
    }

    function focusInput(options = {}) {
      setInputMode("insert", options);
      flashFocusRing(form);
    }

    function moveCursor(delta) {
      const position = input.selectionStart ?? input.value.length;
      const next = Math.max(0, Math.min(input.value.length, position + delta));
      input.setSelectionRange(next, next);
      input.focus();
      updateCursorView();
    }

    function getOutputCursorTargets() {
      return [...output.querySelectorAll(".terminal-line")];
    }

    function clearOutputCursor() {
      clearTextNodeCursor(output);
      for (const element of output.querySelectorAll(".view-cursor-line")) {
        element.classList.remove("view-cursor-line");
      }
    }

    function setOutputCursor(index) {
      const targets = getOutputCursorTargets();
      if (targets.length === 0) {
        return;
      }

      outputCursorIndex = Math.max(0, Math.min(targets.length - 1, index));
      clearOutputCursor();
      const target = targets[outputCursorIndex];
      target.classList.add("view-cursor-line");
      outputCursorColumn = Math.min(outputCursorColumn, getTextLength(target));
      renderTextNodeCursor(target, outputCursorColumn);
      target.scrollIntoView({ block: "nearest" });
    }

    function moveOutputCursor(delta) {
      setOutputCursor(outputCursorIndex + delta);
    }

    function moveOutputCursorColumn(delta) {
      const targets = getOutputCursorTargets();
      const target = targets[outputCursorIndex];
      if (!target) {
        return;
      }

      outputCursorColumn = Math.max(
        0,
        Math.min(getTextLength(target), outputCursorColumn + delta),
      );
      clearTextNodeCursor(target);
      renderTextNodeCursor(target, outputCursorColumn);
    }

    function renderTextNodeCursor(target, column) {
      const walker = document.createTreeWalker(target, NodeFilter.SHOW_TEXT);
      let remaining = column;
      let node = walker.nextNode();

      while (node) {
        const value = node.nodeValue ?? "";
        if (remaining <= value.length) {
          const hasCharacter = remaining < value.length;
          const before = value.slice(0, remaining);
          const cell = hasCharacter ? value[remaining] : " ";
          const after = hasCharacter ? value.slice(remaining + 1) : "";
          const fragment = document.createDocumentFragment();

          if (before) {
            fragment.append(document.createTextNode(before));
          }
          fragment.append(createCursorCell(cell, !hasCharacter));
          if (after) {
            fragment.append(document.createTextNode(after));
          }

          node.replaceWith(fragment);
          return;
        }

        remaining -= value.length;
        node = walker.nextNode();
      }

      target.append(createCursorCell(" ", true));
    }

    function clearTextNodeCursor(root) {
      for (const cursor of root.querySelectorAll(".view-cursor-cell")) {
        const replacement = cursor.dataset.placeholder === "true"
          ? ""
          : cursor.textContent;
        cursor.replaceWith(document.createTextNode(replacement));
      }
      root.normalize();
    }

    function createCursorCell(text, placeholder = false) {
      const span = document.createElement("span");
      span.className = "view-cursor-cell";
      span.textContent = text;
      if (placeholder) {
        span.dataset.placeholder = "true";
      }
      return span;
    }

    function getTextLength(element) {
      clearTextNodeCursor(element);
      return element.textContent.length;
    }

    function flashFocusRing(element) {
      clearTimeout(focusTimer);
      output.classList.remove("focus-ring");
      form.classList.remove("focus-ring");
      element.classList.add("focus-ring");
      focusTimer = setTimeout(() => {
        element.classList.remove("focus-ring");
      }, 1400);
    }

    function updateCursorView() {
      renderCommandCursor();
    }

    function renderCommandCursor() {
      const position = input.selectionStart ?? input.value.length;
      const value = input.value;
      if (inputMode === "visual" && visualAnchor?.pane === "input") {
        const { start, end } = getInputVisualRange();
        const selected = value.slice(start, end);
        const selection = document.createElement("span");
        selection.className = "visual-selection";
        selection.textContent = selected || " ";
        normalCommandView.replaceChildren(
          document.createTextNode(value.slice(0, start)),
          selection,
          document.createTextNode(value.slice(end)),
        );
        return;
      }

      const hasCharacter = position < value.length;
      const before = value.slice(0, position);
      const cell = hasCharacter ? value[position] : " ";
      const after = hasCharacter ? value.slice(position + 1) : "";
      normalCommandView.replaceChildren(
        document.createTextNode(before),
        createCursorCell(cell, !hasCharacter),
        document.createTextNode(after),
      );
    }

    function startVisualSelection() {
      clearVisualSelection();
      inputMode = "visual";
      document.body.dataset.inputMode = "visual";
      updateModeIndicator();

      if (focusPane === "output") {
        clearOutputCursor();
        visualAnchor = {
          pane: "output",
          index: outputCursorIndex,
          column: outputCursorColumn,
        };
        visualFocus = { ...visualAnchor };
        output.focus();
      } else {
        const column = input.selectionStart ?? input.value.length;
        visualAnchor = { pane: "input", column };
        visualFocus = { ...visualAnchor };
        input.focus();
      }

      renderVisualSelection();
    }

    function clearVisualSelection() {
      window.getSelection()?.removeAllRanges();
      visualAnchor = null;
      visualFocus = null;
    }

    function exitVisualSelection() {
      const pane = visualAnchor?.pane;
      clearVisualSelection();
      inputMode = "normal";
      document.body.dataset.inputMode = "normal";
      updateModeIndicator();

      if (pane === "output") {
        focusPane = "output";
        document.body.dataset.focusPane = focusPane;
        output.focus();
        setOutputCursor(outputCursorIndex);
      } else {
        focusPane = "input";
        document.body.dataset.focusPane = focusPane;
        input.focus();
        updateCursorView();
      }
    }

    function extendVisualSelection(key) {
      if (!visualAnchor || !visualFocus) {
        return;
      }

      if (visualAnchor.pane === "output") {
        const targets = getOutputCursorTargets();
        if (targets.length === 0) {
          return;
        }
        if (key === "j" || key === "k") {
          const delta = key === "j" ? 1 : -1;
          visualFocus.index = Math.max(
            0,
            Math.min(targets.length - 1, visualFocus.index + delta),
          );
          outputCursorIndex = visualFocus.index;
          visualFocus.column = Math.min(
            visualFocus.column,
            getTextLength(targets[visualFocus.index]),
          );
          outputCursorColumn = visualFocus.column;
          targets[visualFocus.index]?.scrollIntoView({ block: "nearest" });
        } else if (key === "h" || key === "l") {
          const delta = key === "l" ? 1 : -1;
          const target = targets[visualFocus.index];
          if (!target) {
            return;
          }
          visualFocus.column = Math.max(
            0,
            Math.min(getTextLength(target), visualFocus.column + delta),
          );
          outputCursorColumn = visualFocus.column;
        }
      } else if (key === "h" || key === "l") {
        const delta = key === "l" ? 1 : -1;
        visualFocus.column = Math.max(
          0,
          Math.min(input.value.length, visualFocus.column + delta),
        );
        input.setSelectionRange(visualFocus.column, visualFocus.column);
      }

      renderVisualSelection();
    }

    function renderVisualSelection() {
      if (!visualAnchor || !visualFocus) {
        return;
      }

      if (visualAnchor.pane === "output") {
        const targets = getOutputCursorTargets();
        const range = createVisualRange(targets);
        const selection = window.getSelection();
        selection?.removeAllRanges();
        if (range) {
          selection?.addRange(range);
        }
      } else {
        renderCommandCursor();
      }
    }

    function createVisualRange(targets) {
      const startPosition = compareVisualPositions(visualAnchor, visualFocus) <= 0
        ? visualAnchor
        : visualFocus;
      const endPosition = startPosition === visualAnchor ? visualFocus : visualAnchor;
      const startTarget = targets[startPosition.index];
      const endTarget = targets[endPosition.index];
      if (!startTarget || !endTarget) {
        return null;
      }

      const range = document.createRange();
      const start = getTextPosition(startTarget, startPosition.column);
      const end = getTextPosition(endTarget, endPosition.column + 1);
      range.setStart(start.node, start.offset);
      range.setEnd(end.node, end.offset);
      return range;
    }

    function compareVisualPositions(first, second) {
      if (first.index !== second.index) {
        return first.index - second.index;
      }
      return first.column - second.column;
    }

    function getTextPosition(element, column) {
      const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT);
      let remaining = Math.max(0, column);
      let node = walker.nextNode();
      let lastNode = null;

      while (node) {
        lastNode = node;
        const value = node.nodeValue ?? "";
        if (remaining <= value.length) {
          return { node, offset: remaining };
        }
        remaining -= value.length;
        node = walker.nextNode();
      }

      if (lastNode) {
        return { node: lastNode, offset: lastNode.nodeValue?.length ?? 0 };
      }

      element.append(document.createTextNode(""));
      return { node: element.firstChild, offset: 0 };
    }

    function getInputVisualRange() {
      const anchor = visualAnchor?.column ?? 0;
      const focus = visualFocus?.column ?? anchor;
      const start = Math.min(anchor, focus);
      const end = Math.min(input.value.length, Math.max(anchor, focus) + 1);
      return { start, end };
    }

    function getVisualSelectionText() {
      if (!visualAnchor || !visualFocus) {
        return "";
      }

      if (visualAnchor.pane === "output") {
        return window.getSelection()?.toString() || "";
      }

      const { start, end } = getInputVisualRange();
      return input.value.slice(start, end);
    }

    function copyVisualSelection() {
      const text = getVisualSelectionText();
      if (text && navigator.clipboard) {
        navigator.clipboard.writeText(text);
      }
      exitVisualSelection();
      return text;
    }

    function deleteVisualSelection() {
      if (visualAnchor?.pane !== "input") {
        exitVisualSelection();
        return "";
      }

      const { start, end } = getInputVisualRange();
      const removed = input.value.slice(start, end);
      input.value = `${input.value.slice(0, start)}${input.value.slice(end)}`;
      input.setSelectionRange(start, start);
      exitVisualSelection();
      return removed;
    }

    function changeVisualSelection() {
      const text = getVisualSelectionText();
      if (text && navigator.clipboard) {
        navigator.clipboard.writeText(text);
      }

      if (visualAnchor?.pane === "input") {
        deleteVisualSelection();
        setInputMode("insert");
      } else {
        exitVisualSelection();
      }

      return text;
    }

    function dismissHomeStage() {
      if (homeStage) {
        homeStage.hidden = true;
      }
      if (homeActions) {
        homeActions.hidden = true;
      }
    }

    function restoreHomeStage() {
      if (homeStage) {
        homeStage.hidden = false;
      }
      if (homeActions) {
        homeActions.hidden = false;
      }
    }

    function printHelp() {
      line("available commands:", "accent");
      for (const [command, description] of commands) {
        line(`  ${command.padEnd(16)} ${description}`);
      }
    }

    function printPosts(items) {
      latestResults = items;
      if (items.length === 0) {
        line("no matches", "muted");
        return;
      }

      items.forEach((post, index) => {
        linkLine(
          `[${index + 1}] ${post.date}  ${post.title}  tags: ${post.tags.join(", ")}`,
          post.url,
        );
      });
      line("use `open <number>` to open a result", "muted");
    }

    function printArchive() {
      latestResults = [];
      for (const group of archive) {
        line(group.label, "accent");
        for (const post of group.posts) {
          line(`  ${post.date}  ${post.title}`);
        }
      }
    }

    function printTags() {
      latestResults = [];
      for (const tag of tags) {
        const indent = "  ".repeat(tag.depth);
        line(`${indent}${tag.path} (${tag.count})`);
      }
    }

    function printTag(path) {
      const normalized = path.trim().split("/").filter(Boolean).join("/");
      const items = posts.filter((post) =>
        post.tags.some((tag) => {
          const parts = tag.split("/");
          const paths = parts.map((_, index) => parts.slice(0, index + 1).join("/"));
          return paths.includes(normalized);
        }),
      );
      printPosts(items);
    }

    function printRecent(arg) {
      const count = Number.parseInt(arg, 10);
      const limit = Number.isFinite(count) ? count : 10;
      printPosts(posts.slice(0, Math.max(1, limit)));
    }

    function printTime(arg) {
      const query = arg.trim();
      if (!query) {
        line("usage: time <yyyy|yyyy-mm|yyyy-mm-dd|mm-dd|mm月|dd>", "muted");
        line(`latest defaults come from ${latestDate}`, "muted");
        return;
      }

      const range = parseTimeQuery(query);
      if (!range) {
        line("invalid time query", "muted");
        return;
      }

      const items = posts.filter((post) => {
        if (range.day) return post.date === `${range.year}-${range.month}-${range.day}`;
        if (range.month) return post.date.startsWith(`${range.year}-${range.month}`);
        return post.date.startsWith(range.year);
      });
      printPosts(items);
    }

    function search(query) {
      const tokens = query
        .trim()
        .toLowerCase()
        .split(/\s+/)
        .filter(Boolean);

      if (tokens.length === 0) return [];

      return posts
        .map((post) => ({ post, score: scorePost(post, tokens) }))
        .filter((result) => result.score > 0)
        .sort((a, b) => {
          if (b.score !== a.score) return b.score - a.score;
          return b.post.date.localeCompare(a.post.date);
        })
        .map((result) => result.post);
    }

    function openReader(post) {
      mode = "reader";
      activePost = post;
      savedShellOutput = output.innerHTML;
      prompt.textContent = ":";
      output.replaceChildren();
      outputCursorIndex = 0;
      line(`"${post.slug}.md" ${countLines(post.body) + 5}L`, "muted");
      line(`# ${post.title}`, "accent");
      line("");
      line(`date: ${post.date}`);
      line(`tags: ${post.tags.join(", ")}`);
      line("");
      for (const bodyLine of post.body.split("\n")) {
        line(bodyLine || " ");
      }
      line("");
      line("~", "muted");
      line(":q to close | Esc normal | i/a insert | j/k scroll | g/G top/bottom", "muted");
      output.scrollTop = 0;
      setInputMode("normal");
      focusOutput();
    }

    function closeReader() {
      mode = "shell";
      activePost = null;
      output.innerHTML = savedShellOutput;
      savedShellOutput = "";
      prompt.textContent = "~/blog $";
      output.scrollTop = output.scrollHeight;
      setInputMode("insert");
    }

    function countLines(text) {
      return String(text ?? "").split("\n").length;
    }

    function scorePost(post, tokens) {
      const fields = [
        post.title,
        post.excerpt,
        post.date,
        ...post.tags,
      ].map((field) => String(field).toLowerCase());

      let score = 0;
      for (const token of tokens) {
        const tokenScore = Math.max(...fields.map((field) => scoreField(field, token)));
        if (tokenScore === 0) return 0;
        score += tokenScore;
      }
      return score;
    }

    function scoreField(value, query) {
      if (value.includes(query)) return 100 + query.length;
      if (query.length < 3) return 0;

      let queryIndex = 0;
      let firstMatch = -1;
      let lastMatch = -1;

      for (let index = 0; index < value.length; index += 1) {
        if (value[index] === query[queryIndex]) {
          if (firstMatch === -1) firstMatch = index;
          lastMatch = index;
          queryIndex += 1;
        }

        if (queryIndex === query.length) {
          const span = lastMatch - firstMatch + 1;
          return Math.max(1, 80 - span + query.length);
        }
      }

      return 0;
    }

    function run(rawCommand) {
      const command = rawCommand.trim();
      if (!command) return;

      if (mode === "reader") {
        if (command === ":q" || command === "q") {
          closeReader();
        }
        return;
      }

      dismissHomeStage();
      echo(command);
      const [name, ...rest] = command.split(/\s+/);
      const arg = rest.join(" ");

      if (name.toLowerCase() === "open" && arg.toLowerCase() === "resume") {
        window.location.href = "/resume/";
        return;
      }

      switch (name.toLowerCase()) {
        case "help":
          printHelp();
          break;
        case "search":
          printPosts(search(arg));
          break;
        case "recent":
          printRecent(arg);
          break;
        case "time":
          printTime(arg);
          break;
        case "archive":
          printArchive();
          break;
        case "tags":
          printTags();
          break;
        case "tag":
          printTag(arg);
          break;
        case "resume":
          window.location.href = "/resume/";
          break;
        case "open": {
          const index = Number.parseInt(arg, 10) - 1;
          const post = latestResults[index];
          if (!post) {
            line("invalid post result number", "muted");
            break;
          }
          navigateToPost(post);
          break;
        }
        case "clear":
          output.replaceChildren();
          latestResults = [];
          sessionStorage.removeItem(SHELL_STATE_KEY);
          restoreHomeStage();
          break;
        default:
          line(`unknown command: ${name}`, "muted");
          line("type `help` to list commands", "muted");
      }

      output.scrollTop = output.scrollHeight;
    }

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      run(input.value);
      input.value = "";
      setInputMode("insert");
    });

    input.addEventListener("keydown", handleKeyboard);
    input.addEventListener("input", updateCursorView);
    input.addEventListener("click", updateCursorView);
    input.addEventListener("keyup", updateCursorView);
    output.addEventListener("keydown", handleKeyboard);
    output.addEventListener("click", handlePostLinkClick);
    document.addEventListener("keydown", (event) => {
      if (event.target === input || event.target === output) {
        return;
      }

      handleKeyboard(event);
    });

    function handleKeyboard(event) {
      if (event.ctrlKey && event.key === "j") {
        event.preventDefault();
        focusInput();
        return;
      }

      if (event.ctrlKey && event.key === "k") {
        event.preventDefault();
        focusOutput();
        return;
      }

      if (event.key === "Escape") {
        event.preventDefault();
        if (inputMode === "visual") {
          exitVisualSelection();
          return;
        }
        setInputMode("normal");
        return;
      }

      if (event.key === "Tab") {
        event.preventDefault();
        completeInput();
        return;
      }

      if (inputMode === "insert" && document.activeElement !== input) {
        if (event.key === "i") {
          event.preventDefault();
          focusInput({ append: true });
          return;
        }
      }

      if (inputMode === "insert") {
        return;
      }

      if (inputMode === "visual") {
        if (["h", "j", "k", "l"].includes(event.key)) {
          event.preventDefault();
          extendVisualSelection(event.key);
          return;
        }

        if (event.key === "y") {
          event.preventDefault();
          copyVisualSelection();
          return;
        }

        if (event.key === "c") {
          event.preventDefault();
          changeVisualSelection();
          return;
        }

        if (event.key === "d") {
          event.preventDefault();
          deleteVisualSelection();
          return;
        }

        return;
      }

      if (event.key === "v") {
        event.preventDefault();
        startVisualSelection();
        return;
      }

      if (event.key === "Enter") {
        event.preventDefault();
        activateFocusedLink();
        return;
      }

      if (event.key === "i") {
        if (focusPane === "input" && document.activeElement === input) {
          setInputMode("insert", { append: false });
        } else {
          event.preventDefault();
          focusInput({ append: false });
        }
        return;
      }

      if (event.key === "a") {
        event.preventDefault();
        moveCursor(1);
        focusInput({ append: true });
        return;
      }

      if (event.key === ":") {
        event.preventDefault();
        input.value = ":";
        setInputMode("insert", { append: true });
        return;
      }

      if (event.key === "h") {
        event.preventDefault();
        if (focusPane === "output") {
          moveOutputCursorColumn(-1);
          return;
        }
        moveCursor(-1);
        return;
      }

      if (event.key === "l") {
        event.preventDefault();
        if (focusPane === "output") {
          moveOutputCursorColumn(1);
          return;
        }
        moveCursor(1);
        return;
      }

      if (event.key === "j") {
        event.preventDefault();
        if (focusPane === "output") {
          moveOutputCursor(1);
        } else {
          output.scrollTop += 36;
        }
      } else if (event.key === "k") {
        event.preventDefault();
        if (focusPane === "output") {
          moveOutputCursor(-1);
        } else {
          output.scrollTop -= 36;
        }
      } else if (event.key === "g") {
        event.preventDefault();
        if (focusPane === "output") {
          setOutputCursor(0);
        } else {
          output.scrollTop = 0;
        }
      } else if (event.key === "G") {
        event.preventDefault();
        if (focusPane === "output") {
          setOutputCursor(getOutputCursorTargets().length - 1);
        } else {
          output.scrollTop = output.scrollHeight;
        }
      }
    }

    function completeInput() {
      if (mode === "reader") {
        line(":q", "muted");
        return;
      }

      const value = input.value;
      const [name = "", ...rest] = value.trimStart().split(/\s+/);
      const hasArgumentSpace = /\s$/.test(value) || rest.length > 0;

      if (!hasArgumentSpace) {
        const matches = commandNames.filter((command) => command.startsWith(name));
        applyCompletion(matches, "", "");
        return;
      }

      const command = name.toLowerCase();
      const arg = rest.join(" ");

      if (command === "tag") {
        const matches = tags
          .map((tag) => tag.path)
          .filter((path) => path.startsWith(arg));
        applyCompletion(matches, "tag ", "/");
      } else if (command === "open") {
        if (latestResults.length === 0) {
          line("no article results", "muted");
          return;
        }
        latestResults.forEach((post, index) => {
          line(`${index + 1}  ${post.title}`, "muted");
        });
      } else if (command === "time") {
        line("examples: time 2026 | time 06月 | time 07-02 | time 02", "muted");
        line(`latest defaults come from ${latestDate}`, "muted");
      }
    }

    function applyCompletion(matches, prefix, suffix) {
      if (matches.length === 0) {
        return;
      }

      if (matches.length === 1) {
        input.value = `${prefix}${matches[0]}${suffix || " "}`;
        updateCursorView();
        return;
      }

      line(matches.join("  "), "muted");
    }

    function parseTimeQuery(query) {
      const value = String(query ?? "").trim().toLowerCase();
      if (!value || !latestDate) return null;

      const [latestYear, latestMonth] = latestDate.split("-");
      const normalized = value.replace(/[./]/g, "-");

      const monthMatch = normalized.match(/^(\d{1,2})月$/);
      if (monthMatch) return { year: latestYear, month: pad2(monthMatch[1]) };

      const dayMatch = normalized.match(/^(\d{1,2})日$/);
      if (dayMatch) {
        return { year: latestYear, month: latestMonth, day: pad2(dayMatch[1]) };
      }

      if (/^\d{4}$/.test(normalized)) return { year: normalized };

      if (/^\d{1,2}$/.test(normalized)) {
        return { year: latestYear, month: latestMonth, day: pad2(normalized) };
      }

      const parts = normalized.split("-").filter(Boolean);
      if (parts.length === 2 && parts[0].length === 4) {
        return { year: parts[0], month: pad2(parts[1]) };
      }
      if (parts.length === 2) {
        return { year: latestYear, month: pad2(parts[0]), day: pad2(parts[1]) };
      }
      if (parts.length === 3) {
        return { year: parts[0], month: pad2(parts[1]), day: pad2(parts[2]) };
      }

      return null;
    }

    function pad2(value) {
      return String(value).padStart(2, "0");
    }

    restoreShellState();
    setInputMode("insert");
  </script>
</BaseLayout>
